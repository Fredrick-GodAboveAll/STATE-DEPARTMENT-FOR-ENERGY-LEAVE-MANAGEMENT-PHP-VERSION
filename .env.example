APP_NAME="fleave - Leave Management System"
APP_ENV=local
APP_DEBUG=true

DB_HOST=localhost
DB_NAME=leave_management
DB_USER=root
DB_PASS=

# Email/SMTP Configuration (Optional - for online mode)
# Leave these blank to run in OFFLINE MODE (only login available)
# Configure for Gmail or another SMTP provider for email verification and password reset

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls

# Application URL (used for reset/verification links in emails)
APP_URL=http://localhost:8000

# OFFLINE MODE INFORMATION
# If MAIL_HOST, MAIL_USERNAME, and MAIL_PASSWORD are NOT configured,
# the system automatically enters OFFLINE MODE:
#
# ✅ Available Offline: Login / Logout
# ⚠️  Offline (requires email): Registration, Password Reset, Email Verification
#
# To enable online mode:
# 1. Configure MAIL_HOST and credentials above
# 2. For Gmail: https://myaccount.google.com/apppasswords
# 3. Restart your application
